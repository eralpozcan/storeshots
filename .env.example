# Umami Analytics — privacy-first, cookieless, GDPR-safe.
# Get a website ID from https://cloud.umami.is (free tier: 100k events/mo, 3 sites).
NUXT_PUBLIC_UMAMI_WEBSITE_ID=

# Defaults to Umami Cloud. Override only when self-hosting Umami.
# Example: https://umami.your-domain.com
NUXT_PUBLIC_UMAMI_HOST=https://cloud.umami.is
